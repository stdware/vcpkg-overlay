{
  "name": "synthrt",
  "version": "0.1.0.0",
  "port-version": 6,
  "description": "SVS Synthesis Runtime Library",
  "homepage": "https://github.com/diffscope/synthrt",
  "license": "Apache-2.0",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    },
    "qmsetup",
    "nlohmann-json",
    "stduuid",
    "stdcorelib",
    "bit7z",
    "blake3",
    "sparsepp",
    "syscmdline",
    "re2",
    "cpp-pinyin",
    "luajit",
    {
      "name": "ffmpeg",
      "default-features": false,
      "features": [
        "avcodec",
        "avformat",
        "swresample"
      ]
    }
  ],
  "features": {
    "cuda11": {
      "description": "Enable CUDA 11.x support",
      "supports": "!osx & !arm & !arm64"
    },
    "cuda12": {
      "description": "Enable CUDA 12.x support",
      "supports": "!osx & !arm & !arm64"
    }
  }
}
